# Repository-root ignores — keep credentials, editor state, and local-only
# tooling out of version control. (portal/ has its own .gitignore for the app.)

# Credentials — NEVER commit
key.json

# Editor / IDE
.vscode/
.idea/

# Dependencies (portal/ has its own ignore too; this guards the repo root)
node_modules/

# Test & tooling artifacts
.playwright-mcp/

# OS
.DS_Store

# Local env (real secrets live in portal/.env, ignored there too)
.env

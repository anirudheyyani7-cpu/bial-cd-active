# BIAL backend configuration template. Copy to `.env` (dev) and `.env.test`
# (tests) and fill in real values. NEVER commit a filled-in .env — only this
# template. Required settings have NO default: a missing one fails at startup.

# --- Core (required) ---------------------------------------------------------
# Closed set: development | staging | production
ENVIRONMENT=development
# Async SQLAlchemy URL (asyncpg driver). Local dev points at the compose Postgres.
DATABASE_URL=postgresql+asyncpg://bial:bial@localhost:5544/bial

# --- Core (optional knobs) ---------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Object storage (U6; optional in dev/test, required in production) --------
# Provider select: azure | s3 | r2. Nested keys use the __ delimiter.
# OBJECT_STORE__PROVIDER=azure
# OBJECT_STORE__ACCOUNT_URL=http://127.0.0.1:10000/devstoreaccount1
# OBJECT_STORE__CONTAINER=bial
# OBJECT_STORE__CONNECTION_STRING=...            # one Azure auth mode only
# --- or S3 / MinIO ---
# OBJECT_STORE__PROVIDER=s3
# OBJECT_STORE__BUCKET=bial
# OBJECT_STORE__REGION=us-east-1
# OBJECT_STORE__ACCESS_KEY_ID=...
# OBJECT_STORE__SECRET_ACCESS_KEY=...
# OBJECT_STORE__ENDPOINT_URL=http://localhost:9000   # set for MinIO / S3-compatible

# --- Auth (later phase — not read yet) ---------------------------------------
# JWT_SECRET=change-me-in-production

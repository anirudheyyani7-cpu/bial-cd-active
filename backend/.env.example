# BIAL backend configuration template. Copy to `.env` (dev) and `.env.test`
# (tests) and fill in real values. NEVER commit a filled-in .env — only this
# template. Required settings have NO default: a missing one fails at startup.

# --- Core (required) ---------------------------------------------------------
# Closed set: development | staging | production
ENVIRONMENT=development
# Async SQLAlchemy URL (asyncpg driver). Local dev points at the compose Postgres.
DATABASE_URL=postgresql+asyncpg://bial:bial@localhost:5544/citizen_one

# --- Core (optional knobs) ---------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Object storage (U6; optional in dev/test, required in production) --------
# Azure Blob Storage only. Nested keys use the __ delimiter; set EXACTLY ONE auth
# mode (connection_string with an embedded AccountKey, account_key, or managed
# identity). The Azurite example account_url below matches docker-compose.test.yml.
# OBJECT_STORE__PROVIDER=azure
# OBJECT_STORE__ACCOUNT_URL=http://127.0.0.1:10000/devstoreaccount1
# OBJECT_STORE__CONTAINER=bial
# OBJECT_STORE__CONNECTION_STRING=...            # or ACCOUNT_KEY, or USE_MANAGED_IDENTITY=true

# --- Auth (later phase — not read yet) ---------------------------------------
# JWT_SECRET=change-me-in-production

# Keep the build context small and keep secrets / local junk out of the image.
node_modules
dist
dist-ssr
.env
.env.local
# Real e2e secrets — must never enter the build context/image.
.env.e2e
*.local
.git
.gitignore
.DS_Store
docker-compose.yml
Dockerfile
.dockerignore
npm-debug.log*
# Tests and local-only material — not needed to build or run the app.
**/__tests__
*.test.js
# Host-only e2e harness (runs against the container, never inside it).
e2e
playwright.config.ts
playwright
playwright-report
test-results
.mythos
docs
vercel.json

# ─────────────────────────────────────────────────────────────────────────────
# e2e env template — copy to .env.e2e (GITIGNORED) and fill the <...> secrets.
#
#   cp .env.e2e.example .env.e2e   # then paste the real JWT_SECRET / Foundry key
#
# This is a COMPLETE container env: the single-container image runs the full
# portal server, so it needs the same variable surface as portal/.env (the server
# fails fast at boot on any missing Mongo collection var). Two consumers read it:
#   1. scripts/e2e-container.sh — `docker run --env-file .env.e2e` so the image
#      (portal + in-container Gotenberg) reaches the host's Mongo + Azurite and the
#      live model.
#   2. e2e/auth.setup.ts + scripts/e2e-setup.sh — read E2E_QA_* and JWT_SECRET
#      from here for the container pass (the dev pass falls back to portal/.env).
#
# CONTAINER-NETWORKING GOTCHAS (the "works in dev, not in container" traps):
#   • GOTENBERG_URL = in-container loopback http://localhost:3000 — NOT :3100, NOT
#     a host address. The renderer runs INSIDE this container on :3000.
#   • Mongo + the Azurite blob endpoint must use host.docker.internal (inside a
#     container, 127.0.0.1 is the container itself). The Azurite host is buried
#     INSIDE AZURE_STORAGE_CONNECTION_STRING as BlobEndpoint=… — easy to miss
#     because it is not a standalone variable. e2e-container.sh ALSO forces the
#     GOTENBERG_URL override after --env-file, belt-and-suspenders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude relay (live model — real values required for the @live deck spec) ──
ANTHROPIC_FOUNDRY_API_KEY=<your-foundry-api-key>
AZURE_FOUNDRY_RESOURCE_NAME=bial-genai-vibecoding2
PORT=3001

# ── Database — host Mongo reached from inside the container ───────────────────
MONGODB_URI=mongodb://host.docker.internal:27017/?directConnection=true
MONGODB_DATABASE=citizen_portal
# Collection names (the server requireEnv's every one of these at boot/first use).
MONGODB_USERS_COLLECTION=users
MONGODB_FEEDBACK_COLLECTION=feedback
MONGODB_USAGE_COLLECTION=daily_token_usage
MONGODB_CONVERSATIONS_COLLECTION=conversations
MONGODB_MESSAGES_COLLECTION=messages
MONGODB_ATTACHMENT_USAGE_COLLECTION=attachment_usage
MONGODB_APP_REGISTRY_COLLECTION=app_registry
MONGODB_DATA_RECORDS_COLLECTION=data_records
MONGODB_AUDIT_COLLECTION=audit_logs
MONGODB_APP_FILES_COLLECTION=app_files

# ── Object store — Azure provider via the host's Azurite emulator ────────────
# devstoreaccount1 + the well-known PUBLIC Azurite dev key (not a secret — the
# universal emulator key, already in our committed object-store tests). Only the
# BlobEndpoint host differs from portal/.env: host.docker.internal, not 127.
OBJECT_STORE_PROVIDER=azure
OBJECT_STORE_BUCKET=bial-attachments
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://host.docker.internal:10000/devstoreaccount1;

# ── Daily token limit (server-enforced) ──────────────────────────────────────
DAILY_TOKEN_LIMIT=1000000

# ── JWT — MUST match the secret auth.setup.ts mints the seeded token with ─────
# The container boots with this secret; auth.setup mints the e2e access token with
# the SAME value, so the seeded localStorage token verifies. Use the real local
# JWT_SECRET (from portal/.env) so the dev pass works too.
JWT_SECRET=<your-jwt-secret-64-char-csprng>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Rate-limit / proxy trust (single host, no real proxy in e2e) ─────────────
TRUST_PROXY=1
AUTH_IP_RATE_LIMIT=0

# ── Per-app FILE storage (bytes live in OBJECT_STORE_BUCKET under apps/…) ─────
FILE_SAS_TTL_SECONDS=120
FILE_SAS_SIGNED_IP=
APP_FILE_MAX_JSON=25mb
APP_FILE_MAX_BYTES=18874368
APP_FILE_BYTES_CAP=524288000
APP_FILE_COUNT_CAP=2000
APP_FILE_ALLOWED_TYPES=

# ── Deck (.pptx) attachments — in-container Gotenberg on loopback ─────────────
DECK_ATTACHMENTS_ENABLED=true
GOTENBERG_URL=http://localhost:3000
MAX_DECK_PAGES=100
DECK_CONVERT_TIMEOUT_MS=60000

# ── QA account the specs drive (read by auth.setup, login.spec, e2e-setup) ───
# auth.setup mints a token for E2E_QA_EMAIL; login.spec logs in with the pair;
# e2e-setup.sh provisions the user idempotently. Never commit the real password.
E2E_QA_EMAIL=<qa-user-email>
E2E_QA_PASSWORD=<qa-user-password>

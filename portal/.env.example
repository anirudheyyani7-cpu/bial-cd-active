# ── Claude relay (existing) ───────────────────────────────────────────────
# Server-side only. Keep the Foundry key out of the browser bundle.
ANTHROPIC_FOUNDRY_API_KEY=
AZURE_FOUNDRY_RESOURCE_NAME=
PORT=3001

# ── Cosmos DB for MongoDB (interim auth, shared POC account) ──────────────
# The shared account is a Cosmos *for MongoDB* (RU) account, so we connect with
# the MongoDB driver, NOT the NoSQL/Core SDK. Get the connection string from the
# Azure portal: Cosmos account -> Settings -> Connection strings (it already
# includes ssl=true and the REQUIRED retrywrites=false). The database and the
# `users` collection are pre-created in Data Explorer (see README/setup notes).
MONGODB_URI=mongodb://<account>:<key>@<account>.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&replicaSet=globaldb
MONGODB_DATABASE=citizen_portal
MONGODB_USERS_COLLECTION=users
# Daily per-user token usage counter (the ONLY new persistence). Pre-create this
# collection in Data Explorer alongside `users`; the code never creates it.
MONGODB_USAGE_COLLECTION=daily_token_usage
# User-feedback submissions (append-only). Like the others, pre-create this
# collection in Data Explorer (Cosmos) before deploy; the code never creates it.
# Local dev (the `mongo:7` docker container) auto-creates it on first write, so
# only this env var is needed locally.
MONGODB_FEEDBACK_COLLECTION=feedback
# ── Persistence: chats, messages, attachment quota (server-side, per-user) ──
# Three new collections move a user's work out of the browser and onto the
# server so it follows them across browsers/devices. Pre-create all three in
# Data Explorer (Cosmos) before deploy; the code only resolves handles, never
# creates collections. Local dev (`mongo:7`) auto-creates on first write.
#
# Required composite indexes are created AUTOMATICALLY at boot by
# server/ensure-indexes.js (idempotent) — or run `node scripts/ensure-indexes.js`
# to apply them to a live account without a redeploy. Cosmos for MongoDB 400s a
# filter-on-A + sort-on-B (or multi-field sort) query without one; local Mongo
# does not need them. ensure-indexes.js is the single source of truth, currently:
#   conversations: { username:1, updatedAt:-1 } AND { username:1, kind:1, updatedAt:-1 }
#   messages:      { conversationId:1, username:1, seq:1 }  (single-field sort only — Cosmos 400s a multi-field ORDER BY)
#   feedback:      { createdAt:-1 }
# Partition key (Cosmos): /username on conversations + messages, /_id on
# attachment_usage — matches the per-user read pattern.
#
# conversations: one lightweight HEADER doc per conversation (chat + builder),
# carrying the builder's generated `code.current`. messages: one doc per message
# with a structured `parts[]` array (no unbounded arrays on a growing doc).
# attachment_usage: one doc per user (`_id` = username) with the running byte
# total for the per-user attachment quota.
MONGODB_CONVERSATIONS_COLLECTION=conversations
MONGODB_MESSAGES_COLLECTION=messages
MONGODB_ATTACHMENT_USAGE_COLLECTION=attachment_usage

# ── Object store (attachment bytes) ───────────────────────────────────────
# Attachment BYTES (image/PDF, ≤4 MB) live here, NEVER in the metadata DB — so
# the imminent Cosmos→Postgres migration leaves this layer untouched. Objects
# are written under per-user keys `att/<username>/<attachmentId>`, so a GET
# derived from the JWT can only ever read the caller's own namespace. The
# bucket/container is a deploy prerequisite (the code never creates it).
#
# Pick the backend with OBJECT_STORE_PROVIDER:
#   azure → Azure Blob Storage (native SDK @azure/storage-blob). NOTE: Azure Blob
#           is NOT S3-compatible — it needs this provider, not the S3 client.
#   s3    → any S3-compatible store (AWS S3 / MinIO / R2 / B2 / Spaces / …).
# OBJECT_STORE_BUCKET is the bucket name (s3) or container name (azure).
OBJECT_STORE_PROVIDER=azure
OBJECT_STORE_BUCKET=bial-attachments

# Azure Blob (provider=azure). Storage account → Access keys → Connection string.
# Local dev: the Azurite emulator's well-known devstoreaccount1 string.
AZURE_STORAGE_CONNECTION_STRING=

# S3-compatible (provider=s3). REGION is optional (MinIO ignores it; the SDK
# requires some value — default us-east-1).
OBJECT_STORE_ENDPOINT=http://minio.internal:9000
OBJECT_STORE_ACCESS_KEY=
OBJECT_STORE_SECRET_KEY=
OBJECT_STORE_REGION=us-east-1

# ── Daily token limit (server-enforced) ───────────────────────────────────
# Flat per-user/day ceiling enforced in the /api/claude proxy. Real input+output
# token counts (incl. cache tokens) are captured from the Anthropic stream and
# accumulated per username + IST-date; over-limit requests get a 429 pre-stream.
DAILY_TOKEN_LIMIT=1000000

# ── JWT / token lifetimes ─────────────────────────────────────────────────
# JWT_SECRET MUST be a >=64-char CSPRNG value, shared with the future FastAPI
# service. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Access token TTL (short-lived). Accepts any `ms`/jsonwebtoken duration string.
ACCESS_TOKEN_TTL=15m
# Refresh token TTL (long-lived opaque token).
# Format: <number><s|m|h|d> only (e.g. 7d, 168h, 60m). Other formats (e.g.
# "7 days", "1w") are rejected at startup rather than silently defaulting to 7d.
REFRESH_TOKEN_TTL=7d

# ── Rate limiting / proxy trust ───────────────────────────────────────────
# TRUST_PROXY MUST equal the real number of proxy hops that append to
# X-Forwarded-For (1 for a single load balancer; 2 for e.g. Front Door + App
# Service) so req.ip is the real client IP. A wrong value either lets clients
# spoof their IP or collapses every client to the LB address — which makes the
# per-IP limiter below lock out everyone behind that proxy. Default 1.
TRUST_PROXY=1
# Per-IP ceiling on auth attempts (login + refresh) per 15 min — bounds cross-
# username spraying and the Argon2 cost amplifier. Set to 0 to DISABLE when
# clients genuinely share one ingress IP (corporate NAT); the per-username:IP
# limiters still apply. Default 60.
AUTH_IP_RATE_LIMIT=60

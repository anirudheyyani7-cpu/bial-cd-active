# Combined SINGLE-CONTAINER image for Azure App Service for Containers.
#
# Runs BOTH the BIAL portal (Node API + built SPA) AND the Gotenberg/LibreOffice
# renderer in one deployable — because App Service gives us one container slot and
# we don't want a second server. Gotenberg listens on 127.0.0.1:3000 inside the
# container; the portal calls it at http://localhost:3000. App Service exposes only
# the portal port (set WEBSITES_PORT=3001), so the renderer is never public.
#
# Build (context = the portal/ dir):
#   docker build -f Dockerfile.appservice -t <acr>.azurecr.io/bial-portal:<tag> .
#
# App Service settings (Configuration → Application settings):
#   WEBSITES_PORT=3001
#   DECK_ATTACHMENTS_ENABLED=true
#   GOTENBERG_URL=http://localhost:3000
#   + the usual runtime secrets (ANTHROPIC_FOUNDRY_API_KEY, MONGODB_URI, JWT_SECRET, …)
# Plan sizing: LibreOffice needs real RAM per render. Use B2/B3 (3.5–7 GB) for POC
# or Premium v3 for prod; B1 (1.75 GB) is tight and may OOM on larger decks. Turn
# "Always On" on to avoid cold-start LibreOffice warmups.

# ── Stage 1: build the SPA (needs devDependencies: vite, tailwind, …) ────────
FROM node:22-bookworm-slim AS builder
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

# ── Stage 2: production node_modules only ────────────────────────────────────
FROM node:22-bookworm-slim AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force

# ── Stage 3: runtime = Gotenberg (LibreOffice) + Node + the app ──────────────
# Gotenberg 8 is Debian bookworm based, matching node:22-bookworm-slim, so the
# Node toolchain copied from that image is ABI/glibc compatible.
#
# PIN this base by DIGEST in production to a Gotenberg release whose bundled
# LibreOffice meets the CVE floor (>= 24.8.5 / 25.2.1) — the input bytes are
# untrusted uploads. Verify: docker run --rm <image> libreoffice --version
FROM gotenberg/gotenberg:8

USER root

# MS-metric-compatible fonts so decks don't reflow when their fonts are absent
# (Carlito↔Calibri, Caladea↔Cambria + Liberation/DejaVu/Noto fallbacks; renderer
# hardening rationale in ops/gotenberg/README.md).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      fonts-crosextra-carlito fonts-crosextra-caladea \
      fonts-liberation fonts-dejavu fonts-noto-core fonts-noto-cjk \
 && rm -rf /var/lib/apt/lists/*

# Bring Node + npm over from the official image (same Debian release → compatible).
COPY --from=node:22-bookworm-slim /usr/local/ /usr/local/

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3001
# Renderer is in-container only; the portal reaches it on loopback.
ENV GOTENBERG_URL=http://localhost:3000

# App: prod deps, server code, built SPA, seed/admin scripts, and the entrypoint
# that launches Gotenberg + the portal together.
COPY --from=deps    /app/node_modules ./node_modules
COPY --from=builder /app/dist         ./dist
COPY server.js ./
COPY server ./server
COPY scripts ./scripts
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
# Strip any CR before chmod: a Windows checkout (core.autocrlf) can ship the
# script with CRLF, and a `#!/bin/sh\r` shebang makes the kernel exec `/bin/sh\r`
# -> "no such file or directory" at container start. LF is also enforced via
# .gitattributes; this is belt-and-suspenders since the image is often built on a
# Windows VM via `az acr build`.
RUN sed -i 's/\r$//' /usr/local/bin/docker-entrypoint.sh \
 && chmod +x /usr/local/bin/docker-entrypoint.sh

# Run as the base image's non-root 'gotenberg' user (it owns the renderer's
# writable scratch/profile dirs). The app only READS its files, so root-owned
# world-readable copies above are fine.
USER gotenberg

EXPOSE 3001

# Health: the portal's /preview is an unauthenticated 200 (Node 22 built-in fetch).
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD node -e "fetch('http://localhost:'+(process.env.PORT||3001)+'/preview').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
